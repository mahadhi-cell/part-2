      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "df = pd.read_csv(\"train.csv\")\n",
        "fare = df[\"Fare\"].to_numpy()\n",
        "min_fare = np.min(fare)\n",
        "max_fare = np.max(fare)\n",
        "normalised_fare = (fare - min_fare) / (max_fare - min_fare)\n",
        "print(normalised_fare[:10])"
      ]
    }
  ]
